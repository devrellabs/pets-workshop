---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import DogDetails from '../../components/DogDetails.svelte';

const { id } = Astro.params;
const dogId = parseInt(id || '0');

// Fetch dog data server-side for SEO metadata
interface Dog {
  id: number;
  name: string;
  breed: string;
  age: number;
  description: string;
  gender: string;
  status: string;
}

let dog: Dog | null = null;
try {
  const apiUrl = new URL(`/api/dogs/${dogId}`, Astro.url);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    dog = await res.json() as Dog;
  } else {
    console.error(`Failed to fetch dog ${dogId}: ${res.status} ${res.statusText}`);
  }
} catch (err) {
  console.error(`Error fetching dog ${dogId} for SEO metadata:`, err);
}

const pageTitle = dog ? `${dog.name} - Tailspin Shelter` : "Dog Details - Tailspin Shelter";
const pageDescription = dog
  ? `Meet ${dog.name}, a ${dog.age}-year-old ${dog.breed} available for adoption at Tailspin Shelter in Seattle.`
  : "View dog details and adopt your new best friend at Tailspin Shelter in Seattle.";

// Serialize and sanitize JSON-LD: escape "</" to prevent </script> injection
const jsonLd = dog
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": pageTitle,
      "description": pageDescription,
      "url": Astro.url.toString(),
      "about": {
        "@type": "Thing",
        "name": dog.name,
        "description": dog.description,
        "additionalProperty": [
          { "@type": "PropertyValue", "name": "breed", "value": dog.breed },
          { "@type": "PropertyValue", "name": "age", "value": String(dog.age) },
          { "@type": "PropertyValue", "name": "gender", "value": dog.gender },
          { "@type": "PropertyValue", "name": "status", "value": dog.status },
        ],
      },
    }).replace(/</g, "\\u003c")
  : null;
---

<Layout title={pageTitle} description={pageDescription}>
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} slot="head" />}
  <div class="py-8">
    <DogDetails client:load dogId={dogId} />
    
    <div class="mt-8">
      <a href="/" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all duration-300 inline-flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to All Dogs
      </a>
    </div>
  </div>
</Layout>